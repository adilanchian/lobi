# Copy this to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── GitHub (required for publishing releases + auto-update) ───────────────────
# Generate at: https://github.com/settings/tokens
# Scopes needed: repo (full)
GH_TOKEN=

# ── Apple (required for macOS notarization) ───────────────────────────────────
# Your Apple developer account email
APPLE_ID=

# App-specific password — generate at: https://appleid.apple.com/account/manage
# (not your main Apple ID password)
APPLE_APP_SPECIFIC_PASSWORD=
