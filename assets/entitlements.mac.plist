<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Electron's JS engine (JIT compilation) under hardened runtime -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Required for Electron to load its own unsigned native modules -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Required for Electron to load third-party frameworks -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Lobi-specific: camera for eye tracking -->
  <key>com.apple.security.device.camera</key>
  <true/>
  <!-- Lobi-specific: network for loading MediaPipe model from CDN on first launch -->
  <key>com.apple.security.network.client</key>
  <true/>
</dict>
</plist>
