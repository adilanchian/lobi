{
  "name": "lobi",
  "version": "1.0.0",
  "description": "Focus monitor using eye tracking",
  "author": "Wind Down Studio, LLC",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
