{
  "name": "lobi",
  "version": "2.6.1",
  "description": "Focus monitor using eye tracking",
  "author": "Wind Down Studio, LLC",
  "main": "src/main.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build": "electron-builder --mac --win",
    "publish:mac": "electron-builder --mac --publish always",
    "publish:win": "electron-builder --win --publish always",
    "publish": "electron-builder --mac --win --publish always"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "posthog-node": "^5.34.4"
  }
}
